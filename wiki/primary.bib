@article{Roelfsema2023,
  author  = {Roelfsema, Pieter R.},
  title   = {Solving the Binding Problem: Assemblies Form When Neurons Enhance Their Firing Rate---They Don't Need to Oscillate or Synchronize},
  journal = {Neuron},
  year    = {2023},
  volume  = {111},
  pages   = {1003--1019},
  doi     = {10.1016/j.neuron.2023.03.016},
  annote  = {Perspective arguing BBRE over BBS: V1 curve-tracing synchrony is extremely weak (~0.01 correlation, absent in 1/3 monkeys, same-curve = different-curve); optogenetics shows synchrony doesn't enhance postsynaptic integration; firing rate enhancements causally underlie figure-ground segregation (optogenetic silencing); texture FGM reviewed as BBRE evidence}
