@article{Ray2010,
  author  = {Ray, Supratim and Maunsell, John H. R.},
  title   = {Differences in Gamma Frequencies across Visual Cortex Restrict Their Possible Use in Computation},
  journal = {Neuron},
  year    = {2010},
  volume  = {67},
  pages   = {885--896},
  doi     = {10.1016/j.neuron.2010.08.004},
  annote  = {Gamma frequency in macaque V1 increases with log-contrast (~8 Hz/doubling); spatially varying contrast (Gabor) creates ~10 Hz frequency differences across 400 µm, sharply reducing LFP-LFP coherence; no gamma phase coding of contrast found; gamma is a local E-I resonance phenomenon}
}

